<%= form_with(model: @request, local: true, class: "space-y-6") do |form| %>
  <% if @request.errors.any? %>
    <div class="bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-lg p-4">
      <div class="flex">
        <svg class="h-5 w-5 text-red-400 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
        </svg>
        <div class="ml-3">
          <h3 class="text-sm font-medium text-red-800 dark:text-red-200">
            <%= t('errors.template.header', count: @request.errors.count) %>
          </h3>
          <ul class="mt-2 text-sm text-red-700 dark:text-red-300 list-disc list-inside">
            <% @request.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      </div>
    </div>
  <% end %>

  <!-- Main Info Card -->
  <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md p-6 border border-gray-200 dark:border-gray-700">
    <h2 class="text-xl font-bold text-gray-900 dark:text-gray-100 mb-6">
      <%= t('requests.new.basic_info') %>
    </h2>

    <div class="space-y-5">
      <!-- Title Field -->
      <div data-controller="char-counter" data-char-counter-max-value="100">
        <%= form.label :title, t('requests.new.title_label'), class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
        <span class="sr-only"><%= t('requests.new.title_label') %> <abbr title="required">*</abbr></span>
        <%= form.text_field :title,
            class: "w-full px-3 py-2 border #{@request.errors[:title].any? ? 'border-red-400' : 'border-gray-300 dark:border-gray-600'} rounded-lg focus:ring-2 focus:ring-indigo-500 dark:bg-gray-700 dark:text-white",
            placeholder: t('requests.new.title_placeholder'),
            maxlength: 100,
            required: true,
            "data-char-counter-target": "input",
            "data-action": "input->char-counter#update" %>
        <div class="mt-1 flex justify-between">
          <p class="text-xs text-gray-500 dark:text-gray-400"><%= t('requests.new.title_help') %></p>
          <p class="text-xs text-gray-400"><span data-char-counter-target="count"></span> <%= t('requests.new.chars_remaining') %></p>
        </div>
      </div>

      <!-- Category Field -->
      <div>
        <%= form.label :category_id, t('requests.new.category_label'), class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
        <%= form.select :category_id,
            options_for_select(@categories.map { |c| [c.name, c.id] }, @request.category_id),
            { include_blank: t('requests.new.category_placeholder') },
            class: "w-full px-3 py-2 border #{@request.errors[:category_id].any? ? 'border-red-400' : 'border-gray-300 dark:border-gray-600'} rounded-lg focus:ring-2 focus:ring-indigo-500 dark:bg-gray-700 dark:text-white",
            required: true %>
      </div>

      <!-- Description Field -->
      <div data-controller="char-counter" data-char-counter-max-value="2000">
        <%= form.label :description, t('requests.new.description_label'), class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
        <%= form.text_area :description,
            rows: 5,
            class: "w-full px-3 py-2 border #{@request.errors[:description].any? ? 'border-red-400' : 'border-gray-300 dark:border-gray-600'} rounded-lg focus:ring-2 focus:ring-indigo-500 dark:bg-gray-700 dark:text-white",
            placeholder: t('requests.new.description_placeholder'),
            required: true,
            "data-char-counter-target": "input",
            "data-action": "input->char-counter#update" %>
        <div class="mt-1 flex justify-between">
          <p class="text-xs text-gray-500 dark:text-gray-400"><%= t('requests.new.description_help') %></p>
          <p class="text-xs text-gray-400"><span data-char-counter-target="count"></span> <%= t('requests.new.chars_remaining') %></p>
        </div>
      </div>
    </div>
  </div>

  <!-- Institution Section -->
  <% if @institution || @request.institution_id.present? %>
    <% institution = @institution || @request.institution %>
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md p-6 border border-gray-200 dark:border-gray-700">
      <h2 class="text-xl font-bold text-gray-900 dark:text-gray-100 mb-4 flex items-center gap-2">
        <svg class="w-5 h-5 text-emerald-600 dark:text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
        </svg>
        <%= t('requests.form.institution_section') %>
      </h2>

      <div class="bg-emerald-50 dark:bg-emerald-900/20 rounded-lg p-4 mb-5">
        <p class="text-sm font-medium text-emerald-800 dark:text-emerald-200"><%= institution.name %></p>
        <p class="text-xs text-emerald-600 dark:text-emerald-400 mt-1">
          <%= t("institutions.types.#{institution.institution_type}") %> | <%= institution.full_address %>
        </p>
      </div>

      <%= form.hidden_field :institution_id, value: institution.id %>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <%= form.label :author_name, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" do %>
            <%= t('requests.form.author_name') %> <span class="text-red-500">*</span>
          <% end %>
          <%= form.text_field :author_name,
              class: "w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-emerald-500 dark:bg-gray-700 dark:text-white",
              placeholder: t('requests.form.author_name_placeholder') %>
          <p class="mt-1 text-xs text-gray-500 dark:text-gray-400"><%= t('requests.form.author_name_help') %></p>
        </div>

        <div>
          <%= form.label :help_type, t('requests.form.help_type'), class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
          <%= form.select :help_type,
              Request.help_types.keys.map { |type| [t("help_types.#{type}"), type] },
              {},
              class: "w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-emerald-500 dark:bg-gray-700 dark:text-white" %>
        </div>
      </div>

      <div class="mt-5 p-4 bg-gray-50 dark:bg-gray-700/50 rounded-lg">
        <h3 class="text-sm font-medium text-gray-700 dark:text-gray-300 mb-1"><%= t('requests.form.beneficiary_section') %></h3>
        <p class="text-xs text-gray-500 dark:text-gray-400 mb-3"><%= t('requests.form.beneficiary_help') %></p>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <%= form.label :beneficiary_name, t('requests.form.beneficiary_name'), class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
            <%= form.text_field :beneficiary_name,
                class: "w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-emerald-500 dark:bg-gray-700 dark:text-white",
                placeholder: t('requests.form.beneficiary_name_placeholder') %>
          </div>
          <div>
            <%= form.label :beneficiary_age, t('requests.form.beneficiary_age'), class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
            <%= form.number_field :beneficiary_age,
                class: "w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-emerald-500 dark:bg-gray-700 dark:text-white",
                min: 1, max: 150,
                placeholder: t('requests.form.beneficiary_age_placeholder') %>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <!-- Location Card -->
  <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md p-6 border border-gray-200 dark:border-gray-700">
    <h2 class="text-xl font-bold text-gray-900 dark:text-gray-100 mb-1">
      <%= t('requests.new.location_title') %>
    </h2>
    <p class="text-sm text-gray-600 dark:text-gray-400 mb-5"><%= t('requests.new.location_help') %></p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div>
        <%= form.label :region, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" do %>
          <%= t('requests.new.region_label') %> <span class="text-red-500">*</span>
        <% end %>
        <%= form.select :region,
            options_for_select(I18n.t('regions').map { |k, v| [v, k.to_s] }, @request.region),
            { include_blank: t('requests.new.region_placeholder') },
            class: "w-full px-3 py-2 border #{@request.errors[:region].any? ? 'border-red-400' : 'border-gray-300 dark:border-gray-600'} rounded-lg focus:ring-2 focus:ring-indigo-500 dark:bg-gray-700 dark:text-white",
            required: true %>
      </div>

      <div>
        <%= form.label :city, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" do %>
          <%= t('requests.new.city_label') %> <span class="text-red-500">*</span>
        <% end %>
        <%= form.text_field :city,
            class: "w-full px-3 py-2 border #{@request.errors[:city].any? ? 'border-red-400' : 'border-gray-300 dark:border-gray-600'} rounded-lg focus:ring-2 focus:ring-indigo-500 dark:bg-gray-700 dark:text-white",
            placeholder: t('requests.new.city_placeholder'),
            required: true %>
      </div>
    </div>
  </div>

  <!-- Actions -->
  <div class="flex items-center justify-between">
    <%= link_to t('requests.new.cancel'), requests_path,
        class: "inline-flex items-center px-5 py-2 border border-gray-300 dark:border-gray-600 text-sm font-medium rounded-lg text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-800 hover:bg-gray-50 dark:hover:bg-gray-700 transition" %>

    <%= form.submit (@request.new_record? ? t('requests.new.create') : t('requests.new.update')),
        class: "inline-flex items-center px-8 py-3 border border-transparent text-base font-semibold rounded-lg shadow-sm text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition cursor-pointer",
        data: { turbo_submits_with: t('requests.new.creating') } %>
  </div>
<% end %>
