<%- if controller_name != 'sessions' %>
  <%= link_to t('devise.shared.links.sign_in'), new_session_path(resource_name), class: "font-semibold leading-6 text-indigo-600 dark:text-indigo-400 hover:text-indigo-500 dark:hover:text-indigo-300" %><br />
<% end %>

<%- if devise_mapping.registerable? && controller_name != 'registrations' %>
  <%= link_to t('devise.shared.links.sign_up'), new_registration_path(resource_name), class: "font-semibold leading-6 text-indigo-600 dark:text-indigo-400 hover:text-indigo-500 dark:hover:text-indigo-300" %><br />
<% end %>

<%- if devise_mapping.recoverable? && controller_name != 'passwords' && controller_name != 'registrations' %>
  <%= link_to t('devise.shared.links.forgot_password'), new_password_path(resource_name), class: "font-semibold leading-6 text-indigo-600 dark:text-indigo-400 hover:text-indigo-500 dark:hover:text-indigo-300" %><br />
<% end %>

<%- if devise_mapping.confirmable? && controller_name != 'confirmations' %>
  <%= link_to t('devise.shared.links.no_confirmation'), new_confirmation_path(resource_name), class: "font-semibold leading-6 text-indigo-600 dark:text-indigo-400 hover:text-indigo-500 dark:hover:text-indigo-300" %><br />
<% end %>

<%- if devise_mapping.lockable? && resource_class.unlock_strategy_enabled?(:email) && controller_name != 'unlocks' %>
  <%= link_to t('devise.shared.links.no_unlock'), new_unlock_path(resource_name), class: "font-semibold leading-6 text-indigo-600 dark:text-indigo-400 hover:text-indigo-500 dark:hover:text-indigo-300" %><br />
<% end %>

<%- if devise_mapping.omniauthable? && resource_class.omniauth_providers.any? %>
  <%- resource_class.omniauth_providers.each do |provider| %>
    <%= button_to t('devise.shared.links.sign_in_with', provider: "Google"), send("#{resource_name}_#{provider}_omniauth_authorize_path"), data: { turbo: false }, class: "font-semibold leading-6 text-indigo-600 dark:text-indigo-400 hover:text-indigo-500 dark:hover:text-indigo-300" %><br />
  <% end %>
<% end %>
